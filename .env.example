#
# Twitter/X Accounts
#

# for user which name is manual
BEARER_TOKEN_manual="TOKEN"
CSRF_TOKEN_manual="TOKEN"
AUTH_TOKEN_manual="TOKEN"
GUEST_ID_manual="v1:ID"

#
# Database
#

# PostgreSQL connection string (without scheme prefix - it's added automatically)
DATABASE_URL="user:password@host:5432/dbname"

#
# Machine and account
# 

# X account name (must match the suffix used in BEARER_TOKEN_*, CSRF_TOKEN_*, etc.)
ACCOUNT_NAME="manual"

# Machine identifier (used in source_instance column as {MACHINE_ID}-{account_name})
MACHINE_ID="machine1"
